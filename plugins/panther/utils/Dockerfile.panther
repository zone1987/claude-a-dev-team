# Symfony Panther — headless Chrome im Container (Quelle: panther-docker-ci).
# Beispiel-Image; Versionen/Extensions an dein Projekt anpassen.
FROM php:8.3-cli

# System-Abhängigkeiten + Google Chrome (stable)
RUN apt-get update && apt-get install -y --no-install-recommends \
        git unzip libzip-dev libxml2-dev wget gnupg ca-certificates \
    && wget -q -O /usr/share/keyrings/google-chrome.gpg https://dl.google.com/linux/linux_signing_key.pub \
    && echo "deb [arch=amd64 signed-by=/usr/share/keyrings/google-chrome.gpg] http://dl.google.com/linux/chrome/deb/ stable main" \
        > /etc/apt/sources.list.d/google-chrome.list \
    && apt-get update && apt-get install -y --no-install-recommends google-chrome-stable \
    && docker-php-ext-install zip \
    && rm -rf /var/lib/apt/lists/*

# Composer
COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

WORKDIR /app
COPY composer.json composer.lock* ./
RUN composer install --no-interaction --no-progress --prefer-dist || true

COPY . .

# ChromeDriver passend zu Chrome installieren (dbrekelmans/bdi)
RUN vendor/bin/bdi detect drivers || true

# Headless + no-sandbox + disable-dev-shm-usage sind im Container Pflicht.
ENV PANTHER_NO_SANDBOX=1
ENV PANTHER_CHROME_ARGUMENTS="--disable-dev-shm-usage"

CMD ["vendor/bin/phpunit", "-c", "phpunit.panther.xml"]
