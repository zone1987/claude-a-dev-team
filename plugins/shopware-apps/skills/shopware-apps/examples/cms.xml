<?xml version="1.0" encoding="utf-8" ?>
<cms xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/shopware/trunk/src/Core/Framework/App/Cms/Schema/cms-1.0.xsd">
    <blocks>
        <!-- Two-column text + image block -->
        <block>
            <name>myapp-hero-banner</name>
            <category>text-image</category>
            <label>Hero Banner</label>
            <label lang="de-DE">Hero-Banner</label>
            <slots>
                <slot name="content" type="text">
                    <config>
                        <config-value name="vertical-align" source="static" value="center"/>
                    </config>
                </slot>
                <slot name="image" type="image">
                    <config>
                        <config-value name="display-mode" source="static" value="cover"/>
                        <config-value name="vertical-align" source="static" value="center"/>
                    </config>
                </slot>
            </slots>
            <default-config>
                <margin-top>0px</margin-top>
                <margin-right>0px</margin-right>
                <margin-bottom>20px</margin-bottom>
                <margin-left>0px</margin-left>
                <sizing-mode>full_width</sizing-mode>
            </default-config>
        </block>

        <!-- Three-column feature block -->
        <block>
            <name>myapp-three-features</name>
            <category>text</category>
            <label>Three Features</label>
            <label lang="de-DE">Drei Features</label>
            <slots>
                <slot name="left" type="text">
                    <config>
                        <config-value name="vertical-align" source="static" value="top"/>
                    </config>
                </slot>
                <slot name="center" type="text">
                    <config>
                        <config-value name="vertical-align" source="static" value="top"/>
                    </config>
                </slot>
                <slot name="right" type="text">
                    <config>
                        <config-value name="vertical-align" source="static" value="top"/>
                    </config>
                </slot>
            </slots>
            <default-config>
                <margin-top>20px</margin-top>
                <margin-right>20px</margin-right>
                <margin-bottom>20px</margin-bottom>
                <margin-left>20px</margin-left>
                <sizing-mode>boxed</sizing-mode>
            </default-config>
        </block>
    </blocks>
</cms>
