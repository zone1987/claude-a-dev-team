<?xml version="1.0" encoding="utf-8" ?>
<flow-extensions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/shopware/trunk/src/Core/Framework/App/Flow/Schema/flow-1.0.xsd">

    <!-- Flow Actions -->
    <flow-actions>
        <flow-action>
            <meta>
                <name>myapp.send.notification</name>
                <label>Send App Notification</label>
                <label lang="de-DE">App-Benachrichtigung senden</label>
                <headline>Notification Settings</headline>
                <description>Sends a notification via the app's notification service</description>
                <url>https://my-app.example.com/flow/notify</url>
                <sw-icon>default-communication-envelope</sw-icon>
                <requirements>orderAware</requirements>
                <requirements>customerAware</requirements>
                <delayable>true</delayable>
            </meta>
            <headers>
                <parameter type="string" name="content-type" value="application/json"/>
            </headers>
            <parameters>
                <parameter type="string" name="recipient" value="{{ recipientEmail }}"/>
                <parameter type="string" name="subject" value="{{ subject }}"/>
                <parameter type="string" name="body" value="{{ message }} - Order: {{ order.orderNumber }}"/>
            </parameters>
            <config>
                <input-field type="text">
                    <name>recipientEmail</name>
                    <label>Recipient Email</label>
                    <label lang="de-DE">Empfänger-E-Mail</label>
                    <place-holder>email@example.com</place-holder>
                    <required>true</required>
                </input-field>
                <input-field type="text">
                    <name>subject</name>
                    <label>Subject</label>
                    <label lang="de-DE">Betreff</label>
                    <required>true</required>
                    <defaultValue>Order Notification</defaultValue>
                </input-field>
                <input-field type="textarea">
                    <name>message</name>
                    <label>Message</label>
                    <label lang="de-DE">Nachricht</label>
                    <place-holder>Enter notification message...</place-holder>
                </input-field>
            </config>
        </flow-action>
    </flow-actions>

    <!-- Flow Triggers (Custom Events) -->
    <flow-events>
        <flow-event>
            <name>myapp.order.exported</name>
            <aware>orderAware</aware>
            <aware>customerAware</aware>
        </flow-event>
        <flow-event>
            <name>myapp.product.synced</name>
            <aware>salesChannelAware</aware>
        </flow-event>
    </flow-events>
</flow-extensions>
