    "conventions": {
      "type_nullable": "type ends with '?' means nullable",
      "array_of": "array<T> means collection/array of T",
      "translated": "fields marked 'translated' are resolved via translation fallback chain",
      "always_available": ["eventName", "salesChannelId", "salesChannel"]
    }
  },

