  "$defs": {
    "OrderEntity": {
      "type": "object",
      "entity": "order",
      "properties": {
        "orderNumber": { "type": "string" },
        "orderDateTime": { "type": "DateTimeInterface" },
        "orderDate": { "type": "DateTimeInterface" },
        "amountTotal": { "type": "float" },
        "amountNet": { "type": "float" },
        "positionPrice": { "type": "float" },
        "shippingTotal": { "type": "float" },
        "taxStatus": { "type": "string", "enum": ["gross", "net", "tax-free"] },
        "deepLinkCode": { "type": "string" },
        "affiliateCode": { "type": "string?" },
        "campaignCode": { "type": "string?" },
        "customerComment": { "type": "string?" },
        "internalComment": { "type": "string?" },
        "currencyFactor": { "type": "float" },
        "billingAddressId": { "type": "string" },
        "price": { "$ref": "#/$defs/CartPrice" },
        "shippingCosts": { "$ref": "#/$defs/CalculatedPrice" },
        "totalRounding": { "$ref": "#/$defs/CashRoundingConfig" },
        "itemRounding": { "$ref": "#/$defs/CashRoundingConfig" },
        "currency": { "$ref": "#/$defs/CurrencyEntity" },
        "orderCustomer": { "$ref": "#/$defs/OrderCustomerEntity" },
        "stateMachineState": { "$ref": "#/$defs/StateMachineStateEntity" },
        "billingAddress": { "$ref": "#/$defs/OrderAddressEntity", "note": "via order.addresses.get(order.billingAddressId)" },
        "addresses": { "type": "array<OrderAddressEntity>", "$ref": "#/$defs/OrderAddressEntity" },
        "deliveries": { "type": "array<OrderDeliveryEntity>", "$ref": "#/$defs/OrderDeliveryEntity" },
        "deliveries.first": { "$ref": "#/$defs/OrderDeliveryEntity" },
        "transactions": { "type": "array<OrderTransactionEntity>", "$ref": "#/$defs/OrderTransactionEntity" },
        "transactions.first": { "$ref": "#/$defs/OrderTransactionEntity" },
        "transactions.last": { "$ref": "#/$defs/OrderTransactionEntity" },
        "nestedLineItems": { "type": "array<OrderLineItemEntity>", "$ref": "#/$defs/OrderLineItemEntity", "note": "Hierarchisch verschachtelt" },
        "lineItems": { "type": "array<OrderLineItemEntity>", "$ref": "#/$defs/OrderLineItemEntity", "note": "Flache Liste" },
        "documents": { "type": "array<DocumentEntity>" }
      }
    },

    "OrderCustomerEntity": {
      "type": "object",
      "entity": "order_customer",
      "properties": {
        "email": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "title": { "type": "string?" },
        "company": { "type": "string?" },
        "customerNumber": { "type": "string?" },
        "vatIds": { "type": "array<string>?" },
        "remoteAddress": { "type": "string?" },
        "salutation": { "$ref": "#/$defs/SalutationEntity", "nullable": true },
        "customer": { "$ref": "#/$defs/CustomerEntity", "note": "Live-Kundendatensatz, kann null sein bei Gaesten" }
      }
    },

    "OrderAddressEntity": {
      "type": "object",
      "entity": "order_address",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "street": { "type": "string" },
        "city": { "type": "string" },
        "zipcode": { "type": "string?" },
        "company": { "type": "string?" },
        "department": { "type": "string?" },
        "title": { "type": "string?" },
        "phoneNumber": { "type": "string?" },
        "additionalAddressLine1": { "type": "string?" },
        "additionalAddressLine2": { "type": "string?" },
        "salutation": { "$ref": "#/$defs/SalutationEntity", "nullable": true },
        "country": { "$ref": "#/$defs/CountryEntity" },
        "countryState": { "$ref": "#/$defs/CountryStateEntity", "nullable": true }
      }
    },

    "OrderDeliveryEntity": {
      "type": "object",
      "entity": "order_delivery",
      "properties": {
        "trackingCodes": { "type": "array<string>" },
        "shippingDateEarliest": { "type": "DateTimeInterface" },
        "shippingDateLatest": { "type": "DateTimeInterface" },
        "shippingCosts": { "$ref": "#/$defs/CalculatedPrice" },
        "stateMachineState": { "$ref": "#/$defs/StateMachineStateEntity" },
        "shippingMethod": { "$ref": "#/$defs/ShippingMethodEntity" },
        "shippingOrderAddress": { "$ref": "#/$defs/OrderAddressEntity" },
        "positions": { "type": "array<OrderDeliveryPositionEntity>" }
      }
    },

    "OrderTransactionEntity": {
      "type": "object",
      "entity": "order_transaction",
      "properties": {
        "amount": { "$ref": "#/$defs/CalculatedPrice" },
        "stateMachineState": { "$ref": "#/$defs/StateMachineStateEntity" },
        "paymentMethod": { "$ref": "#/$defs/PaymentMethodEntity" }
      }
    },

    "OrderLineItemEntity": {
      "type": "object",
      "entity": "order_line_item",
      "properties": {
        "label": { "type": "string", "note": "Produktname zum Bestellzeitpunkt" },
        "quantity": { "type": "int" },
        "unitPrice": { "type": "float" },
        "totalPrice": { "type": "float" },
        "description": { "type": "string?" },
        "type": { "type": "string?", "examples": ["product", "promotion", "credit", "custom"] },
        "position": { "type": "int" },
        "good": { "type": "bool" },
        "referencedId": { "type": "string?" },
        "identifier": { "type": "string" },
        "price": { "$ref": "#/$defs/CalculatedPrice", "nullable": true },
        "payload": {
          "type": "array?",
          "properties": {
            "productNumber": { "type": "string" },
            "manufacturerId": { "type": "string?" },
            "taxId": { "type": "string?" },
            "productType": { "type": "string" },
            "categoryIds": { "type": "array<string>" },
            "options": {
              "type": "array",
              "items": { "type": "object", "properties": { "group": { "type": "string" }, "option": { "type": "string" } } }
            },
            "features": { "type": "array" }
          }
        },
        "cover": { "type": "MediaEntity?", "properties": { "url": { "type": "string" } } },
        "product": { "$ref": "#/$defs/ProductEntity", "nullable": true },
        "children": { "type": "array<OrderLineItemEntity>", "note": "Rekursiv" },
        "downloads": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "accessGranted": { "type": "bool" },
              "id": { "type": "string" },
              "media": { "type": "object", "properties": { "fileName": { "type": "string" }, "fileExtension": { "type": "string" } } }
            }
          }
        }
      }
    },

    "CustomerEntity": {
      "type": "object",
      "entity": "customer",
      "properties": {
        "customerNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "title": { "type": "string?" },
        "company": { "type": "string?" },
        "accountType": { "type": "string", "enum": ["private", "business"] },
        "active": { "type": "bool" },
        "guest": { "type": "bool" },
        "birthday": { "type": "DateTimeInterface?" },
        "firstLogin": { "type": "DateTimeInterface?" },
        "lastLogin": { "type": "DateTimeInterface?" },
        "doubleOptInRegistration": { "type": "bool" },
        "doubleOptInConfirmDate": { "type": "DateTimeInterface?" },
        "affiliateCode": { "type": "string?" },
        "campaignCode": { "type": "string?" },
        "vatIds": { "type": "array<string>?" },
        "salutation": { "$ref": "#/$defs/SalutationEntity", "nullable": true },
        "language": { "type": "LanguageEntity" },
        "group": { "$ref": "#/$defs/CustomerGroupEntity" },
        "defaultBillingAddress": { "$ref": "#/$defs/CustomerAddressEntity" },
        "defaultShippingAddress": { "$ref": "#/$defs/CustomerAddressEntity" },
        "lastPaymentMethod": { "$ref": "#/$defs/PaymentMethodEntity", "nullable": true }
      }
    },

    "CustomerAddressEntity": {
      "type": "object",
      "entity": "customer_address",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "street": { "type": "string" },
        "zipcode": { "type": "string?" },
        "city": { "type": "string" },
        "company": { "type": "string?" },
        "department": { "type": "string?" },
        "title": { "type": "string?" },
        "phoneNumber": { "type": "string?" },
        "additionalAddressLine1": { "type": "string?" },
        "additionalAddressLine2": { "type": "string?" },
        "salutation": { "$ref": "#/$defs/SalutationEntity", "nullable": true },
        "country": { "$ref": "#/$defs/CountryEntity" },
        "countryState": { "$ref": "#/$defs/CountryStateEntity", "nullable": true }
      }
    },

    "SalesChannelEntity": {
      "type": "object",
      "entity": "sales_channel",
      "properties": {
        "name": { "type": "string?", "translated": true },
        "shortName": { "type": "string?" },
        "active": { "type": "bool" },
        "taxCalculationType": { "type": "string" },
        "domains": {
          "type": "array<SalesChannelDomainEntity>",
          "items": { "properties": { "url": { "type": "string" }, "languageId": { "type": "string" } } }
        },
        "currency": { "$ref": "#/$defs/CurrencyEntity" },
        "language": { "type": "LanguageEntity" },
        "country": { "$ref": "#/$defs/CountryEntity" },
        "paymentMethod": { "$ref": "#/$defs/PaymentMethodEntity" },
        "shippingMethod": { "$ref": "#/$defs/ShippingMethodEntity" },
        "customerGroup": { "$ref": "#/$defs/CustomerGroupEntity" }
      }
    },

    "CurrencyEntity": {
      "type": "object",
      "entity": "currency",
      "properties": {
        "isoCode": { "type": "string", "example": "EUR" },
        "symbol": { "type": "string", "example": "€" },
        "name": { "type": "string?", "translated": true },
        "shortName": { "type": "string?", "translated": true },
        "factor": { "type": "float" },
        "isSystemDefault": { "type": "bool?" }
      }
    },

    "PaymentMethodEntity": {
      "type": "object",
      "entity": "payment_method",
      "properties": {
        "name": { "type": "string?", "translated": true },
        "distinguishableName": { "type": "string?", "translated": true },
        "description": { "type": "string?", "translated": true },
        "shortName": { "type": "string?" },
        "technicalName": { "type": "string" },
        "active": { "type": "bool" },
        "position": { "type": "int" }
      }
    },

    "ShippingMethodEntity": {
      "type": "object",
      "entity": "shipping_method",
      "properties": {
        "name": { "type": "string?", "translated": true },
        "description": { "type": "string?", "translated": true },
        "trackingUrl": { "type": "string?", "note": "Enthaelt %s als Platzhalter fuer Trackingnummer" },
        "technicalName": { "type": "string" },
        "active": { "type": "bool?" },
        "deliveryTime": { "type": "DeliveryTimeEntity" }
      }
    },

    "StateMachineStateEntity": {
      "type": "object",
      "entity": "state_machine_state",
      "properties": {
        "technicalName": {
          "type": "string",
          "examples": {
            "order": ["open", "in_progress", "completed", "cancelled"],
            "order_delivery": ["open", "shipped", "shipped_partially", "returned", "returned_partially", "cancelled"],
            "order_transaction": ["open", "paid", "paid_partially", "refunded", "refunded_partially", "cancelled", "failed", "reminded", "authorized", "chargeback", "unconfirmed"]
          }
        },
        "name": { "type": "string?", "translated": true, "example": "Offen" }
      }
    },

    "SalutationEntity": {
      "type": "object",
      "entity": "salutation",
      "properties": {
        "salutationKey": { "type": "string", "examples": ["mr", "mrs", "not_specified"] },
        "letterName": { "type": "string?", "translated": true, "example": "Sehr geehrter Herr" },
        "displayName": { "type": "string?", "translated": true, "example": "Herr" }
      }
    },

    "CountryEntity": {
      "type": "object",
      "entity": "country",
      "properties": {
        "name": { "type": "string?", "translated": true },
        "iso": { "type": "string?", "example": "DE" },
        "iso3": { "type": "string?", "example": "DEU" }
      }
    },

    "CountryStateEntity": {
      "type": "object",
      "entity": "country_state",
      "properties": {
        "name": { "type": "string?", "translated": true },
        "shortCode": { "type": "string" }
      }
    },

    "CustomerGroupEntity": {
      "type": "object",
      "entity": "customer_group",
      "properties": {
        "name": { "type": "string?", "translated": true },
        "displayGross": { "type": "bool" }
      }
    },

    "NewsletterRecipientEntity": {
      "type": "object",
      "entity": "newsletter_recipient",
      "properties": {
        "email": { "type": "string" },
        "firstName": { "type": "string?" },
        "lastName": { "type": "string?" },
        "title": { "type": "string?" },
        "zipCode": { "type": "string?" },
        "city": { "type": "string?" },
        "street": { "type": "string?" },
        "status": { "type": "string", "enum": ["notSet", "direct", "optIn", "optOut"] },
        "hash": { "type": "string", "note": "Fuer Abmelde-/Bestaedigungslinks" },
        "confirmedAt": { "type": "DateTimeInterface?" },
        "salutation": { "$ref": "#/$defs/SalutationEntity", "nullable": true }
      }
    },

    "ProductEntity": {
      "type": "object",
      "entity": "product",
      "properties": {
        "productNumber": { "type": "string" },
        "name": { "type": "string?", "translated": true },
        "description": { "type": "string?", "translated": true },
        "ean": { "type": "string?" },
        "manufacturerNumber": { "type": "string?" },
        "stock": { "type": "int" },
        "availableStock": { "type": "int?" },
        "weight": { "type": "float?" },
        "width": { "type": "float?" },
        "height": { "type": "float?" },
        "length": { "type": "float?" },
        "ratingAverage": { "type": "float?" },
        "manufacturer": { "type": "ProductManufacturerEntity?", "properties": { "name": { "type": "string?", "translated": true } } },
        "cover": { "type": "ProductMediaEntity?", "properties": { "media": { "properties": { "url": { "type": "string" } } } } }
      }
    },

    "CartPrice": {
      "type": "object",
      "properties": {
        "totalPrice": { "type": "float" },
        "rawTotal": { "type": "float" },
        "netPrice": { "type": "float" },
        "taxStatus": { "type": "string" },
        "calculatedTaxes": {
          "type": "array",
          "items": { "$ref": "#/$defs/CalculatedTax" }
        }
      }
    },

    "CalculatedPrice": {
      "type": "object",
      "properties": {
        "totalPrice": { "type": "float" },
        "unitPrice": { "type": "float" },
        "quantity": { "type": "int" },
        "calculatedTaxes": { "type": "array", "items": { "$ref": "#/$defs/CalculatedTax" } }
      }
    },

    "CalculatedTax": {
      "type": "object",
      "properties": {
        "taxRate": { "type": "float" },
        "tax": { "type": "float" },
        "price": { "type": "float" }
      }
    },

    "CashRoundingConfig": {
      "type": "object",
      "properties": {
        "decimals": { "type": "int" },
        "interval": { "type": "float" },
        "roundForNet": { "type": "bool" }
      }
    },

    "A11yDocument": {
      "type": "object",
      "properties": {
        "documentId": { "type": "string" },
        "deepLinkCode": { "type": "string" },
        "fileExtension": { "type": "string" }
      }
    },

    "ContactFormData": {
      "type": "array_map",
      "properties": {
        "email": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "phone": { "type": "string?" },
        "subject": { "type": "string?" },
        "comment": { "type": "string" }
      }
    },

    "RevocationRequestFormData": {
      "type": "array_map",
      "note": "Neu in Shopware 6.7",
      "properties": {
        "contractNumber": { "type": "string?" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "comment": { "type": "string?" },
        "submitTime": { "type": "DateTimeInterface" }
      }
    },

    "ReviewFormData": {
      "type": "array_map",
      "properties": {
        "id": { "type": "string?" },
        "name": { "type": "string?" },
        "lastName": { "type": "string?" },
        "email": { "type": "string?" },
        "points": { "type": "int" },
        "title": { "type": "string" },
        "content": { "type": "string" }
      }
    }
  }
}
